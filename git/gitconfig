[user]
    name = Sam Macaluso
    email = sam@macalu.so

[alias]
    update = add -u .
    unstage = reset HEAD
    untracked = status -u .

[mergetool]
    path = /usr/local/bin/nvim
    prompt = false

[diff]
    renames = copy
    tool = nvimdiff

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    pager = diff-so-fancy | less --tabs=4 -RFX
