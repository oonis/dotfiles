[user]
    name = Sam Macaluso
    email = sam@macalu.so
    signingkey = 04CCF6E87094EF3E

[alias]
    update = add -u .
    unstage = reset HEAD
    untracked = status -u .

[mergetool]
    path = /usr/local/bin/nvim
    prompt = false

[diff]
    renames = copy
    tool = nvimdiff

[github]
    user = oonis

[commit]
    gpgsign = true

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    pager = diff-so-fancy | less --tabs=4 -RFX

[gpg]
    program = /usr/local/MacGPG2/bin/gpg2
